# Internal Docker address of the n8n container.
# Uses the Docker service name as hostname (resolved within the shared Docker network).
N8N_BASE_URL=http://n8n:5678

# Port the middleware listens on inside the container.
# Only change this if you also update the Traefik label and Dockerfile EXPOSE.
PORT=3000

# Traefik public domain for middleware proxy
N8N_MIDDLEWARE_HOST=n8n.mydomain.com
